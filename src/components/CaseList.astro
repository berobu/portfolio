---
// Case study list — grid layout
---

<section class="case-list" id="work">

  <p class="section-label">WORK</p>

  <div class="grid">

    <!-- Card 01 — Underwriting Rule Engine -->
    <a class="card card--link" href="/case/ure">
      <div class="card-image">
        <div class="card-image-inner">
          <img src="/assets/cases/ure/canvas-after-light.png" alt="" />
        </div>
      </div>
      <p class="card-meta">Fintech · B2B SaaS · 0→1</p>
      <h2 class="card-title">Underwriting Rule Engine</h2>
      <p class="card-description">No-code platform for risk managers to build and manage business rules without engineering.</p>
      <p class="card-metric" aria-hidden="true">↳ Rule engine rebuilt · Solo · AI-assisted process</p>
    </a>

    <!-- Card 02 — Loan Management System -->
    <div class="card card--muted">
      <div class="card-image card-image--empty">
        <p class="card-coming-soon">Coming Soon</p>
      </div>
      <p class="card-meta">Fintech · B2B SaaS · 0→1</p>
      <h2 class="card-title card-title--muted">Loan Management System</h2>
      <p class="card-description">Core banking interface for managing loan lifecycle — part of the same fintech ecosystem as the Underwriting Rule Engine.</p>
    </div>

  </div>

</section>

<style>
  .case-list {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.14em;
    color: var(--color-text-muted);
    text-transform: uppercase;
    margin: 0 0 16px;
  }

  /* ─── Grid ─────────────────────────────────────────── */
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  /* ─── Card base ─────────────────────────────────────── */
  .card {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  /* ─── Image container ───────────────────────────────── */
  .card-image {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-default);
    border-radius: 12px;
    padding: 24px;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 45 / 32;
  }

  .card-image-inner {
    position: absolute;
    inset: 24px;
    border-radius: 6px;
    overflow: hidden;
  }

  .card-image-inner img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  /* ─── Coming soon ───────────────────────────────────── */
  .card-coming-soon {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.14em;
    color: var(--color-text-muted);
    text-transform: uppercase;
    margin: 0;
  }

  /* ─── Meta ──────────────────────────────────────────── */
  .card-meta {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.10em;
    color: var(--color-text-muted);
    text-transform: uppercase;
    margin: 16px 0 0;
  }

  /* ─── Title ─────────────────────────────────────────── */
  .card-title {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--color-text-primary);
    margin: 4px 0 0;
  }

  .card-title--muted {
    color: var(--color-text-muted);
  }

  /* ─── Description ───────────────────────────────────── */
  .card-description {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin: 8px 0 0;
  }

  /* ─── Hover metric ──────────────────────────────────── */
  .card-metric {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    color: var(--color-accent);
    margin: 8px 0 0;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 150ms ease, transform 150ms ease;
  }

  .card--link:hover .card-metric {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 640px) {
    .case-list {
      padding: 0 20px;
    }
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
