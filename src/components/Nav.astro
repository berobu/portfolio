---
// Nav — SPEC-content-v1 + SPEC-design-v1
interface Props {
  showBack?: boolean;
}
const { showBack = false } = Astro.props;
---

<header class="nav">
  <div class="nav-left">
    <a href="/" class="nav-name">Igor Bielov</a>
    {showBack && (
      <a href="/" class="nav-link">← Work</a>
    )}
  </div>
  <nav class="nav-links">
    <a href="#work" class="nav-link">Work</a>
    <a href="/cv.pdf" class="nav-link" target="_blank" rel="noopener noreferrer">CV&nbsp;↗</a>
  </nav>
</header>

<style>
  .nav {
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav-name {
    font-family: var(--font-mono);
    font-size: var(--font-size-nav);
    font-weight: 400;
    letter-spacing: var(--letter-spacing-nav);
    color: var(--color-text-secondary);
    text-decoration: none;
    text-transform: uppercase;
    transition: color 150ms ease;
  }

  .nav-name:hover {
    color: var(--color-accent);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: var(--font-size-nav);
    font-weight: 400;
    letter-spacing: var(--letter-spacing-nav);
    color: var(--color-text-secondary);
    text-decoration: none;
    text-transform: uppercase;
    transition: color 150ms ease;
  }

  .nav-link:hover {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .nav {
      padding: 24px 20px;
    }
  }
</style>
