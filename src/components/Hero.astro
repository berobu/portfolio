---
// Hero section — SPEC-design-v1 + SPEC-content-v1
// Animation: staggered word reveal, ~600ms total, ease-out, one time
import AsciiSequence from './AsciiSequence';

// Headline split into two lines per spec ("breaks after 'interfaces'")
const line1 = ['Clear,', 'considered', 'interfaces'];
const line2 = ['for', 'complex', 'products.'];

// Timing: 6 words × 50ms stagger + 350ms duration = 600ms total
const STAGGER_MS = 50;
const DURATION_MS = 350;
---

<section class="hero">
  <div class="hero-content">
    <p class="eyebrow">Product Designer</p>

    <h1 class="headline" aria-label="Clear, considered interfaces for complex products.">
      {line1.map((word, i) => (
        <>
          <span
            class="word"
            style={`animation: word-reveal ${DURATION_MS}ms ease-out ${i * STAGGER_MS}ms both;`}
            aria-hidden="true"
          >{word}</span>{i < line1.length - 1 ? ' ' : ''}
        </>
      ))}
      <br />
      {line2.map((word, i) => (
        <>
          <span
            class="word"
            style={`animation: word-reveal ${DURATION_MS}ms ease-out ${(line1.length + i) * STAGGER_MS}ms both;`}
            aria-hidden="true"
          >{word}</span>{i < line2.length - 1 ? ' ' : ''}
        </>
      ))}
    </h1>

    <p class="subline">
      I bring rigour to ambiguous briefs and stay in it until the thing actually ships.
    </p>
  </div>

  <div class="animation-zone">
    <AsciiSequence client:only="react" />
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 900px;
    overflow: hidden;
  }

  .hero-content {
    position: absolute;
    bottom: 150px;
    left: 0;
    right: 0;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
    z-index: 2;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--font-size-label);
    font-weight: 400;
    letter-spacing: var(--letter-spacing-label);
    color: var(--color-accent);
    text-transform: uppercase;
    margin: 0 0 8px;
  }

  .headline {
    font-family: var(--font-display);
    font-size: 3.75rem; /* 60px */
    font-weight: 800;
    letter-spacing: var(--letter-spacing-display);
    line-height: var(--line-height-display);
    color: var(--color-text-primary);
    margin: 0 0 16px;
  }

  .word {
    display: inline-block;
  }

  .subline {
    font-family: var(--font-mono);
    font-size: var(--font-size-body);
    font-weight: 400;
    letter-spacing: var(--letter-spacing-body);
    line-height: var(--line-height-body);
    color: var(--color-text-secondary);
    margin: 0;
  }

  .animation-zone {
    position: absolute;
    top: 0;
    right: 0;
    width: 100%;
    height: 900px;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
    display: flex;
    justify-content: flex-end;
    transform: translateX(-50px);
  }

  @media (max-width: 640px) {
    .hero-content {
      padding: 0 20px;
    }

    .animation-zone {
      opacity: 0.4;
    }
  }
</style>
