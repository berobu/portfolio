  }

  /* ── Before / After ─────────────────────────────────────────── */
  .before-after {
    display: flex;
    gap: 24px;
  }

  .ba-col {
    flex: 1;
    min-width: 0;
  }

  .ba-label {
    font-family: var(--font-mono);
    font-size: var(--font-size-meta);
    font-weight: 400;
    letter-spacing: var(--letter-spacing-meta);
    color: var(--color-text-muted);
    text-transform: uppercase;
    margin: 10px 0 0;
  }

  /* ── Screenshot frame ───────────────────────────────────────── */
  .screenshot-frame {
    background-color: var(--color-bg-surface);
    border: 1px solid var(--color-border-default);
    border-radius: 10px;
    padding: 20px;
    position: relative;
    overflow: hidden;
  }

  .screenshot-frame--wide {
    padding: 20px;
  }

  .screenshot-img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 4px;
    transition: opacity 100ms ease;
  }

  /* ── Placeholder frame ──────────────────────────────────────── */
  .screenshot-frame--placeholder {
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border-style: dashed;
    border-color: var(--color-border-muted);
  }

  .placeholder-label {
    font-family: var(--font-mono);
    font-size: var(--font-size-meta);
    font-weight: 400;
    letter-spacing: var(--letter-spacing-meta);
    color: var(--color-text-faint);
    text-transform: uppercase;
  }

  /* ── Dark / Light toggle ────────────────────────────────────── */
  .toggle {
    position: absolute;
    top: 14px;
    right: 16px;
    display: flex;
    align-items: center;
    gap: 4px;
    z-index: 1;
  }

  .toggle-btn {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    font-weight: 400;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: color 150ms ease;
  }

  .toggle-btn.active {
    color: var(--color-text-primary);
  }

  .toggle-sep {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    color: var(--color-text-faint);
    line-height: 1;
    pointer-events: none;
  }

  /* ── Scroll fade-in ─────────────────────────────────────────── */
  .fade-in-el {
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 400ms ease,
      transform 400ms ease;
  }

  .fade-in-el.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Mobile — single column ─────────────────────────────────── */
  @media (max-width: 860px) {
    .case-page {
      grid-template-columns: 1fr;
      padding: 0 24px;
    }

    .case-panel {
      position: static;
      height: auto;
      padding: 40px 0 32px;
