<script is:inline>
  (function () {
    const states = [
      { label: 'TEST MODE', state: 'test',    light: '/assets/cases/ure/DT-TestMode-Start-1.png',   dark: '/assets/cases/ure/DT-TestMode-Start.png'     },
      { label: 'SUCCESS',   state: 'success', light: '/assets/cases/ure/DT-TestMode-Success.png',   dark: '/assets/cases/ure/DT-TestMode-Success-1.png' },
      { label: 'WARNING',   state: 'warning', light: '/assets/cases/ure/DT-TestMode-Warning.png',   dark: '/assets/cases/ure/DT-TestMode-Warning-1.png' },
    ];
    let stateIdx = 0;
    let theme = 'light';

    const img       = document.querySelector('.dt-switcher-img');
    const label     = document.querySelector('.dt-state-label');
    const prevBtn   = document.querySelector('.dt-arrow-prev');
    const nextBtn   = document.querySelector('.dt-arrow-next');
    const themeBtns = document.querySelectorAll('.dt-theme-btn');

    const dtTrack = document.querySelector('.dt-switcher-theme-toggle');
    const dtInd = document.createElement('span');
    dtInd.className = 'toggle-indicator';
    dtTrack.insertBefore(dtInd, dtTrack.firstChild);

    function moveDtInd(btn) {
      dtInd.style.width = btn.offsetWidth + 'px';
      dtInd.style.transform = 'translateX(' + btn.offsetLeft + 'px)';
    }

    requestAnimationFrame(function () {
      const active = dtTrack.querySelector('.dt-theme-btn.active');
      if (active) {
        dtInd.style.transition = 'none';
        moveDtInd(active);
        requestAnimationFrame(function () { dtInd.style.transition = ''; });
      }
    });

    function render() {
      const s = states[stateIdx];
      img.src = s[theme];
      label.textContent = s.label;
      label.dataset.state = s.state;
    }

    prevBtn.addEventListener('click', () => {
      stateIdx = (stateIdx - 1 + states.length) % states.length;
      render();
    });

    nextBtn.addEventListener('click', () => {
      stateIdx = (stateIdx + 1) % states.length;
      render();
    });

    themeBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        theme = btn.dataset.theme;
        themeBtns.forEach(function (b) {
          b.classList.remove('active');
          const svg = b.querySelector('svg');
          if (svg) svg.setAttribute('stroke', '#F2EDE4');
        });
        btn.classList.add('active');
        const svg = btn.querySelector('svg');
        if (svg) svg.setAttribute('stroke', '#D4FF3E');
        moveDtInd(btn);
        render();
      });
    });
  })();
</script>

