<script is:inline>
  (function () {
    const btns = document.querySelectorAll('.hero-toggle-btn');
    const img  = document.querySelector('.hero-image');
    const srcs = {
      light: '/assets/cases/ure/hero-canvas-light.png',
      dark:  '/assets/cases/ure/hero-canvas-dark.png',
    };

    const track = document.querySelector('.hero-toggle');
    const ind = document.createElement('span');
    ind.className = 'toggle-indicator';
    track.insertBefore(ind, track.firstChild);

    function moveInd(btn) {
      ind.style.width = btn.offsetWidth + 'px';
      ind.style.transform = 'translateX(' + btn.offsetLeft + 'px)';
    }

    requestAnimationFrame(function () {
      const active = track.querySelector('.hero-toggle-btn.active');
      if (active) {
        ind.style.transition = 'none';
        moveInd(active);
        requestAnimationFrame(function () { ind.style.transition = ''; });
      }
    });

    btns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        btns.forEach(function (b) {
          b.classList.remove('active');
          const svg = b.querySelector('svg');
          if (svg) svg.setAttribute('stroke', '#F2EDE4');
        });
        btn.classList.add('active');
        const svg = btn.querySelector('svg');
        if (svg) svg.setAttribute('stroke', '#D4FF3E');
        moveInd(btn);
        img.src = srcs[btn.dataset.mode];
      });
    });
  })();
</script>

